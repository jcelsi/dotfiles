{
    "workbench.colorTheme": "GitHub Dark Default",
    "workbench.startupEditor": "none",
    "prettier.tabWidth": 4,
    "git.enableSmartCommit": true,
    "editor.formatOnSave": true,
    "git.confirmSync": false,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
    },
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[css]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
    },
    "[html]": {

        "editor.formatOnSave": true
    },
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
    },
    "[javascriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
    },
    "[tailwindcss]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
    },
    "[vue]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
    },

    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "javascript.updateImportsOnFileMove.enabled": "always",
    "typescript.updateImportsOnFileMove.enabled": "always",
    "git.autofetch": true,
    "explorer.confirmDelete": false,
    "editor.wordWrap": "wordWrapColumn",
    "editor.wordWrapColumn": 120,
    "editor.largeFileOptimizations": false,
    "explorer.confirmDragAndDrop": false,
    "cmake.showOptionsMovedNotification": false,
    "editor.minimap.enabled": false,
    "editor.copyWithSyntaxHighlighting": false,
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.emptySelectionClipboard": false,
    "workbench.editor.enablePreview": false,
    "window.newWindowDimensions": "inherit",
    "editor.multiCursorModifier": "ctrlCmd",
    "files.trimTrailingWhitespace": true,
    "diffEditor.renderSideBySide": false,
    "editor.snippetSuggestions": "top",
    "editor.detectIndentation": true,
    "window.nativeFullScreen": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "workbench.editor.showTabs": "multiple",
    "breadcrumbs.enabled": false,
    "scm.diffDecorations": "none",
    "editor.hover.delay": 300,
    "editor.hover.enabled": "on",
    "editor.matchBrackets": "always",
    "workbench.tips.enabled": false,
    "editor.colorDecorators": true,
    "git.decorations.enabled": false,
    "editor.lightbulb.enabled": "on",
    "editor.selectionHighlight": false,
    "editor.overviewRulerBorder": false,
    "editor.renderLineHighlight": "none",
    "editor.occurrencesHighlight": "off",
    "problems.decorations.enabled": false,
    "editor.renderControlCharacters": false,
    "editor.hideCursorInOverviewRuler": true,
    "editor.gotoLocation.multipleReferences": "goto",
    "editor.gotoLocation.multipleDefinitions": "goto",
    "editor.gotoLocation.multipleDeclarations": "goto",
    "workbench.editor.enablePreviewFromQuickOpen": false,
    "editor.gotoLocation.multipleImplementations": "goto",
    "editor.gotoLocation.multipleTypeDefinitions": "goto",
    "editor.fontFamily": "Geist Mono, JetBrains Mono, Fira Code",
    "editor.suggestFontSize": 13,
    "editor.suggestLineHeight": 30,
    "terminal.integrated.lineHeight": 1.1,
    "terminal.integrated.fontFamily": "Hack Nerd Font",
    "terminal.integrated.fontSize": 13,
    "editor.fontSize": 13,
    "editor.lineHeight": 20,
    "search.useIgnoreFiles": false,
    "search.exclude": {
        "**/vendor/{[^l],?[^ai]}*": true,
        "**/public/{[^i],?[^n]}*": true,
        "**/node_modules": true,
        "**/dist": true,
        "**/_ide_helper.php": true,
        "**/composer.lock": true,
        "**/package-lock.json": true,
        "storage": true,
        ".phpunit.result.cache": true,
        "**/coverage": true,
        "**/.nyc_output": true,
        "**/.buildspecs": true,
        "**/newrelic_agent.log": true,
        "**/vendor/bin": true,
        "**/vendor/composer": true,
        "**/vendor/laravel/framework": true,
        "**/vendor/laravel/sail": true,
        "**/vendor/laravel/tinker": true,
        "**/docs": true
    },
    "editor.wordSeparators": "`~!@#%^&*()=+[{]}\\|;:'\",.<>/?",
    "emmet.includeLanguages": {
        "blade": "html",
        "vue-html": "html",
        "vue": "html",
        "react": "html",
        "javascript": "html"
    },
    "files.associations": {
        ".php_cs": "php",
        ".php_cs.dist": "php"
    },

    "prettier.requireConfig": true,
    "prettier.useEditorConfig": false,
    "explorer.sortOrder": "type",
    "workbench.tree.indent": 15,
    "editor.quickSuggestions": {
        "strings": true
    },
    "security.workspace.trust.untrustedFiles": "open",
    "editor.linkedEditing": true,
    "editor.fontLigatures": "'ss01', 'ss02', 'ss03', 'ss04', 'ss05', 'ss06', 'ss07', 'ss08', 'calt', 'dlig'",
    "diffEditor.wordWrap": "on",
    "notebook.output.wordWrap": true,
    "editor.minimap.maxColumn": 250,
    "codesnap.containerPadding": "8em",
    "codesnap.boxShadow": "rgba(0, 0, 0, 0.55) 0px 12px 24px",
    "editor.accessibilitySupport": "off",
    "chat.editor.wordWrap": "on",
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": [
                    "comment",
                    "keyword",
                    "variable.language",
                    "entity.other.attribute-name.html",
                    "entity.other.attribute-name",
                    "keyword.control",
                    "storage.type",
                    "comment",
                    "comment.block",
                    "comment.line"
                ],
                "settings": {
                    "fontStyle": ""
                }
            }
        ]
    },
    "material-icon-theme.saturation": 0,
    "vscode_custom_css.imports": [
        "file:///Users/jortice/dev/vscode-settings/settings.css",
        "file:///D://vs/vs-script.js"
    ],
    "material-icon-theme.files.color": "#42a5f5",
    "workbench.tree.enableStickyScroll": false,
    "editor.inlineSuggest.suppressSuggestions": true,
    "editor.padding.top": 14,
    "editor.cursorBlinking": "solid",
    "editor.stickyScroll.enabled": false,
    "editor.guides.indentation": true,
    "window.menuBarVisibility": "compact",
    "workbench.iconTheme": "catppuccin-mocha",
    "files.exclude": {
        "**/dist": true,
        "**/coverage": true,
        "**/docs": true,
        "**/.nyc_output": true,
        "**/.buildspecs": true,
        "**/.git": true,
        "**/node_modules": true,
        "**/vendor": true,
        "**/storage": true,
        "**/.vscode": true,
        "**/.cm": true
    },
    "terminal.integrated.padding": { "top": 0 },
    "terminal.integrated.stickyScroll.enabled": false,
    "editor.hover.hidingDelay": 300,
    "editor.hover.above": true,
    "editor.hover.sticky": true,
    "github.copilot.enable": {
        "*": true,
        "plaintext": false,
        "markdown": true,
        "scminput": false
    },
    "terminal.integrated.profiles.osx": {
        "bash": {
            "path": "bash",
            "args": [
                "-l"
            ],
            "icon": "terminal-bash"
        },
        "zsh": {
            "path": "zsh",
            "args": [
                "-l"
            ]
        },
        "fish": {
            "path": "/opt/homebrew/bin/fish",
            "args": [
                "-l"
            ]
        },
        "tmux": {
            "path": "tmux",
            "icon": "terminal-tmux"
        },
        "pwsh": {
            "path": "pwsh",
            "icon": "terminal-powershell"
        }
    },
    "terminal.integrated.defaultProfile.osx": "fish"
}
